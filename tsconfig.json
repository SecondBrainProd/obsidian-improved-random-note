{
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ESNext",
        "moduleResolution": "Node",
        "lib": [
            "DOM",
            "ESNext"
        ],
        "strict": true,
        "sourceMap": true,
        "inlineSources": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": ".",
        "baseUrl": "."
    },
    "include": [
        "main.ts"
    ]
}