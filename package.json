{
  "name": "obsidian-improved-random-note-pro",
  "version": "2.0.2",
  "description": "Open a random note based on filters like folders, tags and properties.",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild main.ts --bundle --external:obsidian --format=cjs --watch --outfile=main.js",
    "build": "esbuild main.ts --bundle --external:obsidian --format=cjs --minify --outfile=main.js"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "random",
    "note"
  ],
  "author": "Dmitriy Laukhin",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.1",
    "eslint-plugin-obsidian": "^2.29.0",
    "obsidian": "latest",
    "typescript": "latest"
  }
}